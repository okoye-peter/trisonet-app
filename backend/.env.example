PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Authentication
JWT_SECRET=your_super_secret_jwt_key
